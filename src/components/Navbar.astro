---
const BOOKS_URL = 'https://booksy.com/es-es/55338_randy-barber-shop_barberia_53745_mostoles';

interface Props {
  currentPage?: string;
}

const { currentPage } = Astro.props;

const navLinks = [
  { label: 'Inicio', href: '#home' },
  { label: 'Nosotros', href: '#about' },
  { label: 'Servicios', href: '#services' },
  { label: 'Galería', href: '#gallery' },
  { label: 'Equipo', href: '#team' },
  { label: 'Contacto', href: '#contact' },
];
---

<header id="navbar" class="fixed top-0 left-0 w-full z-50 transition-all duration-300">
  <nav class="container mx-auto flex items-center justify-between px-5 md:px-8 lg:px-12 py-4">
    <a href="#home" class="font-heading text-2xl font-bold text-gold tracking-wide">
      RANDY
    </a>

    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium tracking-wide uppercase transition-colors duration-200',
            currentPage === link.href
              ? 'text-gold'
              : 'text-white hover:text-gold',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href={BOOKS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-gold text-dark-900 px-6 py-2 rounded-full font-semibold text-sm hover:bg-gold-light transition-all"
      >
        Reservar
      </a>
    </div>

    <button
      id="mobile-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Abrir menú"
    >
      <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="bar2"></span>
      <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="bar3"></span>
    </button>
  </nav>

  <div
    id="mobile-menu"
    class="fixed inset-0 bg-dark-950 z-40 flex flex-col items-center justify-center gap-8 translate-y-[-100%] transition-transform duration-500 ease-in-out md:hidden"
  >
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="text-xl font-heading text-white hover:text-gold transition-colors duration-200"
        id={`mobile-link-${link.label.toLowerCase()}`}
      >
        {link.label}
      </a>
    ))}
    <a
      href={BOOKS_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="bg-gold text-dark-900 px-8 py-3 rounded-full font-semibold text-base hover:bg-gold-light transition-all mt-4"
    >
      Reservar
    </a>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar');
  const mobileToggle = document.getElementById('mobile-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  let menuOpen = false;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('bg-[var(--color-dark-900)]', 'backdrop-blur-lg', 'border-b', 'border-[var(--color-dark-600)]/50');
      navbar?.classList.remove('bg-transparent');
    } else {
      navbar?.classList.add('bg-transparent');
      navbar?.classList.remove('bg-[var(--color-dark-900)]', 'backdrop-blur-lg', 'border-b', 'border-[var(--color-dark-600)]/50');
    }
  });

  function toggleMenu() {
    menuOpen = !menuOpen;
    if (menuOpen) {
      mobileMenu?.classList.remove('translate-y-[-100%]');
      mobileMenu?.classList.add('translate-y-0');
      bar1 && (bar1.style.transform = 'rotate(45deg) translate(5px, 5px)');
      bar2 && (bar2.style.opacity = '0');
      bar3 && (bar3.style.transform = 'rotate(-45deg) translate(5px, -5px)');
    } else {
      mobileMenu?.classList.add('translate-y-[-100%]');
      mobileMenu?.classList.remove('translate-y-0');
      bar1 && (bar1.style.transform = 'rotate(0) translate(0, 0)');
      bar2 && (bar2.style.opacity = '1');
      bar3 && (bar3.style.transform = 'rotate(0) translate(0, 0)');
    }
  }

  mobileToggle?.addEventListener('click', toggleMenu);

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (menuOpen) toggleMenu();
    });
  });
</script>
