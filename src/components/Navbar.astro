---
interface Props {
  currentPage?: string;
}

const { currentPage } = Astro.props;

const BOOKS_URL = 'https://booksy.com/es-es/55338_randy-barber-shop_barberia_53745_mostoles';

const navLinks = [
  { label: 'Inicio', href: '#home' },
  { label: 'Nosotros', href: '#about' },
  { label: 'Servicios', href: '#services' },
  { label: 'Galería', href: '#gallery' },
  { label: 'Equipo', href: '#team' },
  { label: 'Contacto', href: '#contact' },
];
---

<header
  id="navbar"
  class="fixed top-0 w-full bg-dark-950/90 backdrop-blur-md z-50 border-b border-dark-600/50 transition-transform duration-300"
>
  <div class="container mx-auto px-5">
    <nav class="flex justify-between items-center h-16 md:h-20">
      <a
        href="/#home"
        class="font-heading text-xl md:text-2xl font-bold text-gold tracking-wide transition-all duration-300"
        aria-label="Ir al inicio"
      >
        RANDY
      </a>

      <div class="hidden min-[1028px]:flex gap-3 min-[1500px]:gap-5 2xl:gap-7 items-center">
        <a
          href="#home"
          class="text-xs lg:text-sm font-medium tracking-wide uppercase transition-colors duration-200 text-white hover:text-gold"
        >
          Inicio
        </a>
        <a
          href="#services"
          class="text-xs lg:text-sm font-medium tracking-wide uppercase transition-colors duration-200 text-white hover:text-gold"
        >
          Servicios
        </a>
        <a
          href="#gallery"
          class="text-xs lg:text-sm font-medium tracking-wide uppercase transition-colors duration-200 text-white hover:text-gold"
        >
          Galería
        </a>
        <a
          href="#team"
          class="hidden min-[1500px]:block text-xs lg:text-sm font-medium tracking-wide uppercase transition-colors duration-200 text-white hover:text-gold"
        >
          Equipo
        </a>
        <a
          href="#about"
          class="hidden min-[1500px]:block text-xs lg:text-sm font-medium tracking-wide uppercase transition-colors duration-200 text-white hover:text-gold"
        >
          Nosotros
        </a>
        <a
          href="#contact"
          class="text-xs lg:text-sm font-medium tracking-wide uppercase transition-colors duration-200 text-white hover:text-gold"
        >
          Contacto
        </a>
        <a
          href={BOOKS_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-gold text-dark-900 px-5 py-1.5 lg:px-6 lg:py-2 rounded-full font-semibold text-xs lg:text-sm hover:bg-gold-light transition-colors duration-200 whitespace-nowrap shrink-0"
        >
          Reservar
        </a>
      </div>

      <div class="flex gap-4 items-center">
        <button
          id="menu-toggle"
          class="min-[1500px]:hidden text-white text-2xl focus:outline-none cursor-pointer p-2 hover:text-gold transition-colors"
          aria-label="Abrir menú"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" y1="6" x2="20" y2="6"></line>
            <line x1="4" y1="12" x2="20" y2="12"></line>
            <line x1="4" y1="18" x2="20" y2="18"></line>
          </svg>
        </button>
      </div>
    </nav>
  </div>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 w-screen h-dvh z-[100] bg-dark-950/95 backdrop-blur-xl flex flex-col items-center justify-center gap-8 translate-x-full transition-transform duration-300 min-[1500px]:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Menú principal"
  aria-hidden="true"
  tabindex="-1"
>
  <button
    id="menu-close"
    class="absolute top-6 right-6 text-white text-3xl p-4 focus:outline-none hover:text-gold transition-colors"
    aria-label="Cerrar menú"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <nav class="flex flex-col items-center gap-8">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="text-3xl font-black font-heading text-white hover:text-gold transition-colors mobile-link uppercase tracking-tighter"
        id={`mobile-link-${link.label.toLowerCase()}`}
      >
        {link.label}
      </a>
    ))}
    <a
      href={BOOKS_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="bg-gold text-dark-950 px-8 py-3 rounded-full font-bold text-lg hover:bg-gold-light transition-all mt-4"
    >
      Reservar
    </a>
  </nav>
</div>

<style>
  @keyframes soft-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.15);
      opacity: 0.75;
    }
  }
</style>

<script>
  const menuToggle = document.getElementById('menu-toggle')
  const menuClose = document.getElementById('menu-close')
  const mobileMenu = document.getElementById('mobile-menu')
  const mobileLinks = document.querySelectorAll('.mobile-link')
  const focusableSelectors =
    'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])'
  let lastFocusedElement: HTMLElement | null = null

  const getFocusableElements = () => {
    if (!mobileMenu) return []
    return Array.from(
      mobileMenu.querySelectorAll<HTMLElement>(focusableSelectors)
    ).filter((el) => {
      return !el.hasAttribute('disabled') && el.getAttribute('aria-hidden') !== 'true'
    })
  }

  function openMenu() {
    mobileMenu?.classList.remove('translate-x-full')
    mobileMenu?.setAttribute('aria-hidden', 'false')
    menuToggle?.setAttribute('aria-expanded', 'true')
    menuToggle?.setAttribute('aria-label', 'Cerrar menú')
    lastFocusedElement = document.activeElement as HTMLElement
    const firstFocusable = mobileMenu?.querySelector<HTMLElement>(focusableSelectors)
    firstFocusable?.focus()
    document.body.style.overflow = 'hidden'
  }

  function closeMenu() {
    mobileMenu?.classList.add('translate-x-full')
    mobileMenu?.setAttribute('aria-hidden', 'true')
    menuToggle?.setAttribute('aria-expanded', 'false')
    menuToggle?.setAttribute('aria-label', 'Abrir menú')
    lastFocusedElement?.focus()
    document.body.style.overflow = ''
  }

  menuToggle?.addEventListener('click', openMenu)
  menuClose?.addEventListener('click', closeMenu)
  mobileLinks.forEach((link) => link.addEventListener('click', closeMenu))

  document.addEventListener('keydown', (event) => {
    const isMenuVisible = mobileMenu
      ? !mobileMenu.classList.contains('translate-x-full')
      : false
    if (!isMenuVisible) return

    if (event.key === 'Escape') {
      closeMenu()
      return
    }

    if (event.key !== 'Tab') return
    const focusable = getFocusableElements()

    if (focusable.length === 0) {
      event.preventDefault()
      return
    }

    const first = focusable[0]
    const last = focusable[focusable.length - 1]
    const isShift = event.shiftKey

    if (!isShift && document.activeElement === last) {
      event.preventDefault()
      first.focus()
    } else if (isShift && document.activeElement === first) {
      event.preventDefault()
      last.focus()
    }
  })

  let lastScroll = 0
  const header = document.querySelector('header')

  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY
    if (currentScroll <= 0) {
      header?.classList.remove('-translate-y-full')
      return
    }

    if (
      currentScroll > lastScroll &&
      !mobileMenu?.classList.contains('translate-x-full')
    ) {
      // scrolling down while menu is open — do not hide header
    } else if (currentScroll > lastScroll && currentScroll > 80) {
      header?.classList.add('-translate-y-full')
    } else {
      header?.classList.remove('-translate-y-full')
    }
    lastScroll = currentScroll
  })
</script>
