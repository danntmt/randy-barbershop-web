---
import Container from './Container.astro';
import SectionTitle from './SectionTitle.astro';

const reviews = [
  {
    quote: 'Excelente servicio.',
    name: 'Yeferson',
    service: 'Corte de Pelo',
    barber: 'José',
  },
  {
    quote: 'Perfecto.',
    name: 'Rodrigo',
    service: 'Corte de Pelo',
    barber: 'Alejandro',
  },
  {
    quote: 'Impecable.',
    name: 'Javier',
    service: 'Corte de Pelo',
    barber: 'Randy',
  },
  {
    quote: 'Como siempre un servicio muy profesional y cercano.',
    name: 'José',
    service: 'Arreglo de Barba',
    barber: 'Randy',
  },
  {
    quote: 'Muy satisfecho.',
    name: 'Fco Javier',
    service: 'Arreglo de Barba',
    barber: 'Alejandro',
  },
  {
    quote: 'Muy contento con mi corte. La atención es muy cercana y agradable. Un placer.',
    name: 'Israel',
    service: 'Corte + Arreglo Barba',
    barber: 'Alejandro',
  },
];
---

<section id="testimonials" class="bg-dark-800 py-20 md:py-32">
  <Container>
    <SectionTitle subtitle="Testimonios" title="Lo Que Dicen Nuestros Clientes" />

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        reviews.map((review) => (
          <div class="bg-dark-700 rounded-2xl p-8 border border-dark-600/30">
            <div class="flex items-center justify-between mb-5">
              <span class="text-xs font-medium gold-text uppercase tracking-wider">{review.service}</span>
              <div class="text-gold text-sm" aria-label="5 out of 5 stars">★★★★★</div>
            </div>
            <p class="text-gray-300 leading-relaxed mb-5">
              {review.quote}
            </p>
            <div class="flex items-center gap-3 pt-4 border-t border-dark-600/30">
              <div class="h-8 w-8 rounded-full bg-dark-600 flex items-center justify-center">
                <span class="text-xs font-semibold text-gray-300">{review.name.charAt(0)}</span>
              </div>
              <div>
                <p class="font-semibold text-white text-sm">{review.name}</p>
                <p class="text-gray-500 text-xs">{review.barber}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>
