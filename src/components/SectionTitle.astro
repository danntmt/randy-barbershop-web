---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'center' | 'left';
  light?: boolean;
}

const {
  title,
  subtitle,
  align = 'center',
  light = false,
} = Astro.props;
---

<div class:list={['mb-12 md:mb-16', align === 'center' ? 'text-center' : 'text-left']}>
  {subtitle && (
    <span class="inline-block text-gold text-sm tracking-[0.2em] uppercase font-semibold mb-4">
      {subtitle}
    </span>
  )}
  <h2 class:list={['font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-balance', light ? 'text-gold' : 'text-white']}>
    {title}
  </h2>
  <div class:list={['mt-6 h-px w-16 bg-gold', align === 'center' ? 'mx-auto' : '']}></div>
</div>
