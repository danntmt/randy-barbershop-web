---
import { Image } from 'astro:assets';
import Container from './Container.astro';
import SectionTitle from './SectionTitle.astro';
import gallery1 from '../assets/images/gallery-1.jpg';
import gallery2 from '../assets/images/gallery-2.jpg';
import gallery3 from '../assets/images/gallery-3.jpg';
import gallery4 from '../assets/images/gallery-4.jpg';
import ig1 from '../assets/images/ig-1.jpg';
import ig2 from '../assets/images/ig-2.jpg';
import ig3 from '../assets/images/ig-3.jpg';
import ig4 from '../assets/images/ig-4.jpg';

const images = [gallery1, gallery2, gallery3, gallery4, ig1, ig2, ig3, ig4];
---

<section id="gallery" class="bg-dark-900 py-20 md:py-32">
  <Container>
    <SectionTitle
      subtitle="Galería"
      title="Nuestro Trabajo Habla por Sí Mismo"
    />

    <div class="columns-2 gap-4 space-y-4 md:columns-3 lg:columns-4">
      {images.map((img, i) => (
        <div
          class="group relative cursor-pointer overflow-hidden rounded-xl break-inside-avoid"
        >
          <Image
            src={img}
            alt={`Gallery image ${i + 1}`}
            class="w-full object-cover transition-transform duration-500 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-dark-900/0 transition-all duration-500 group-hover:bg-dark-900/40"></div>
          <div class="absolute inset-0 rounded-xl border border-transparent transition-all duration-500 group-hover:border-gold/30"></div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a
        href="https://www.instagram.com/randybarbershop_official/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 gold-text text-sm font-semibold hover:underline"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        Ver más en Instagram
      </a>
    </div>
  </Container>
</section>
