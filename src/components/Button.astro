---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  external?: boolean;
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  class: className = '',
} = Astro.props;

const baseClasses = 'inline-flex items-center justify-center gap-2 rounded-full font-semibold tracking-wide transition-all duration-300';

const variantClasses: Record<string, string> = {
  primary: 'bg-gold text-dark-900 hover:bg-gold-light',
  secondary: 'bg-dark-700 text-white hover:bg-dark-500',
  outline: 'border border-gold text-gold hover:bg-gold hover:text-dark-900',
  ghost: 'text-white hover:text-gold transition-all duration-200',
};

const sizeClasses: Record<string, string> = {
  sm: 'px-5 py-2 text-sm',
  md: 'px-8 py-3 text-base',
  lg: 'px-10 py-4 text-lg',
};

const combinedClasses = [baseClasses, variantClasses[variant], sizeClasses[size], className].filter(Boolean).join(' ');
---

{
  href ? (
    <a
      href={href}
      class={combinedClasses}
      target={external ? '_blank' : undefined}
      rel={external ? 'noopener noreferrer' : undefined}
    >
      <slot />
    </a>
  ) : (
    <button class={combinedClasses}>
      <slot />
    </button>
  )
}
