---
const BOOKS_URL = 'https://booksy.com/es-es/55338_randy-barber-shop_barberia_53745_mostoles';

const quickLinks = [
  { label: 'Inicio', href: '#home' },
  { label: 'Nosotros', href: '#about' },
  { label: 'Servicios', href: '#services' },
  { label: 'Galería', href: '#gallery' },
  { label: 'Equipo', href: '#team' },
  { label: 'Contacto', href: '#contact' },
];

const services = [
  'Corte de Pelo',
  'Arreglo de Barba',
  'Degradado',
  'Afeitado con Toalla',
  'Experiencia Premium',
  'Ritual Supremo',
];
---

<footer class="bg-dark-950 border-t border-dark-600/50 pt-16">
  <div class="mx-auto px-5 md:px-8 lg:px-12 max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <div>
        <a href="#home" class="font-heading text-2xl font-bold text-gold tracking-wide">
          RANDY
        </a>
        <p class="mt-4 text-sm text-gray-400 leading-relaxed">
          Barbería premium en Móstoles. Cortes de precisión, barberos expertos, experiencia de lujo.
        </p>
        <a
          href="https://www.instagram.com/randybarbershop_official/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-4 text-sm text-gray-400 hover:text-gold transition-colors duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
          @randybarbershop_official
        </a>
      </div>

      <div>
        <h3 class="font-heading text-lg font-bold text-white mb-4">Enlaces Rápidos</h3>
        <ul class="space-y-2.5">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-gray-400 hover:text-gold transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-heading text-lg font-bold text-white mb-4">Servicios</h3>
        <ul class="space-y-2.5">
          {services.map((service) => (
            <li class="text-sm text-gray-400">{service}</li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-heading text-lg font-bold text-white mb-4">Contacto y Horario</h3>
        <div class="space-y-3 text-sm text-gray-400">
          <p>Av. de la Constitución, 41, 28931 Móstoles</p>
          <p>642 15 13 41</p>
          <div class="pt-2 space-y-1">
            <p>Lun–Vie: 10:00 – 20:00</p>
            <p>Sáb: 10:00 – 15:00</p>
            <p>Dom: Cerrado</p>
          </div>
        </div>
        <a
          href={BOOKS_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block mt-5 text-sm text-gold underline underline-offset-4 hover:text-gold-light transition-colors duration-200 font-semibold"
        >
          Reservar
        </a>
      </div>

    </div>

    <div class="border-t border-dark-600/50 py-6 mt-12 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-500">
        &copy; 2026 Randy Barber Shop. Todos los derechos reservados.
      </p>
      <p class="text-xs text-gray-500">
        Hecho con pasión
      </p>
    </div>
  </div>
</footer>
