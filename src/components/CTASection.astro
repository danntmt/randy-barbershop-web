---
import Container from './Container.astro';

const BOOKS_URL = 'https://booksy.com/es-es/55338_randy-barber-shop_barberia_53745_mostoles';
---

<section id="booking" class="bg-dark-950 py-24 md:py-36">
  <Container>
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-white text-balance">
        ¿Listo para tu Próximo Look?
      </h2>

      <p class="text-gray-400 text-lg mt-6">
        Reserva tu cita ahora y vive la experiencia de la mejor barbería de Móstoles.
      </p>

      <p class="text-gold text-sm mt-4">
        5.0 ★★★★★ &nbsp;&nbsp; +500 reseñas
      </p>

      <div class="mt-10">
        <a
          href={BOOKS_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block rounded-full bg-gold px-10 py-4 text-center text-base font-semibold text-dark-950 transition-all duration-300 hover:bg-gold-light hover:shadow-lg hover:shadow-gold/20"
        >
          Reservar Cita en Booksy
        </a>
      </div>

      <p class="text-gray-500 text-xs mt-4">
        Cancelación gratuita · Sin cita previa · Todas las edades
      </p>
    </div>
  </Container>
</section>
