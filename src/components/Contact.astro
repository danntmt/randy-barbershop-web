---
import Container from './Container.astro';
import SectionTitle from './SectionTitle.astro';

const BOOKS_URL = 'https://booksy.com/es-es/55338_randy-barber-shop_barberia_53745_mostoles';
---

<section id="contact" class="bg-dark-800 py-20 md:py-32">
  <Container>
    <SectionTitle subtitle="Encuéntranos" title="Visita Nuestra Barbería" />

    <div class="grid md:grid-cols-2 gap-12">
      <div class="bg-dark-700 rounded-2xl p-8 border border-dark-600/30">
        <div class="flex items-center gap-3 mb-6">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-gold flex-shrink-0"
          >
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          <div>
            <p class="font-semibold text-white">Av. de la Constitución, 41</p>
            <p class="text-gray-400 text-sm">28931 Móstoles</p>
          </div>
        </div>

        <div class="space-y-4 text-sm text-gray-400">
          <div class="flex items-center gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-gold flex-shrink-0"
            >
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
            <span>642 15 13 41</span>
          </div>

          <div class="flex items-center gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-gold flex-shrink-0"
            >
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
              <polyline points="22,6 12,13 2,6" />
            </svg>
            <span>info@randybarbershop.com</span>
          </div>
        </div>

        <div class="mt-8 pt-6 border-t border-dark-600/50">
          <h4 class="font-heading text-lg font-semibold text-white mb-3">Horario</h4>
          <ul class="space-y-2 text-sm text-gray-400">
            <li class="flex justify-between">
              <span>Lunes — Viernes</span>
              <span class="text-gray-300">10:00 – 20:00</span>
            </li>
            <li class="flex justify-between">
              <span>Sábado</span>
              <span class="text-gray-300">10:00 – 15:00</span>
            </li>
            <li class="flex justify-between">
              <span>Domingo</span>
              <span class="text-gray-300">Cerrado</span>
            </li>
          </ul>
        </div>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            href="https://www.instagram.com/randybarbershop_official/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-full border border-dark-600/50 px-6 py-3 text-sm text-gray-400 hover:text-gold hover:border-gold transition-colors duration-200"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
            </svg>
            Instagram
          </a>
          <a
            href={BOOKS_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-full bg-gold px-8 py-3 text-sm font-semibold text-dark-950 transition-all duration-300 hover:bg-gold-light"
          >
            Reservar
          </a>
        </div>
      </div>

      <div class="rounded-2xl overflow-hidden border border-dark-600/30 h-80 md:h-full min-h-[320px]">
        <iframe
          src="https://www.google.com/maps?q=Avenida+de+la+Constituci%C3%B3n+41+M%C3%B3stoles&output=embed&z=16&t=m"
          width="100%"
          height="100%"
          style="border: 0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Randy Barber Shop location"
          class="grayscale invert hue-rotate-180 contrast-75"
        ></iframe>
      </div>
    </div>
  </Container>
</section>
