---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero-1.jpg';

const BOOKS_URL = 'https://booksy.com/es-es/55338_randy-barber-shop_barberia_53745_mostoles';
---

<section
  id="home"
  class="relative min-h-screen overflow-hidden"
>
  <div class="absolute inset-0 animate-zoom-in">
    <Image
      src={heroImage}
      alt="Randy Barber Shop interior"
      class="h-full w-full object-cover"
      loading="eager"
    />
  </div>

  <div class="absolute inset-0 bg-gradient-to-b from-dark-900/60 via-dark-900/40 to-dark-900"></div>

  <div class="relative z-10 flex h-full min-h-screen items-center">
    <div class="w-full px-6 md:px-10 lg:px-16 xl:px-24">
      <div class="animate-fade-up" id="hero-content">
        <h1 class="font-heading text-4xl font-bold leading-tight text-white md:text-6xl lg:text-7xl xl:text-8xl max-w-4xl">
          Precisión. Estilo. Confianza.
        </h1>

        <p class="mt-6 max-w-2xl text-base text-gray-300 md:text-lg lg:text-xl">
          Experiencia premium de barbería para el caballero moderno.
        </p>

        <p class="mt-4 text-sm gold-text">
          5.0 ★★★★★ &nbsp; +500 reseñas
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href={BOOKS_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block rounded-full bg-gold px-8 py-4 text-center text-sm font-semibold text-dark-950 transition-all duration-300 hover:bg-gold-light hover:shadow-lg hover:shadow-gold/20"
          >
            Reservar Cita
          </a>
          <a
            href="#services"
            class="inline-block rounded-full border border-gold px-8 py-4 text-center text-sm font-semibold gold-text transition-all duration-300 hover:bg-gold/10"
          >
            Nuestros Servicios
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 z-10 -translate-x-1/2" id="scroll-indicator">
    <div class="flex flex-col items-center gap-2">
      <span class="text-xs uppercase tracking-widest text-gray-400">Desliza</span>
      <svg
        class="h-5 w-5 animate-bounce text-gold"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>
</section>

<script>
  const content = document.getElementById('hero-content');
  if (content) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          content.classList.add('animate-fade-in');
          observer.unobserve(content);
        }
      },
      { threshold: 0.3 }
    );
    observer.observe(content);
  }
</script>
