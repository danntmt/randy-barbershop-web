<button
  id="back-to-top"
  class="fixed bottom-6 left-4 md:bottom-6 md:left-6 z-40 w-10 h-10 rounded-full bg-dark-700 border border-dark-500 text-white flex items-center justify-center hover:bg-gold hover:text-dark-900 hover:border-gold transition-all duration-300 opacity-0 pointer-events-none backdrop-blur-sm transition-opacity"
  aria-label="Back to top"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <line x1="12" y1="19" x2="12" y2="5"></line>
    <polyline points="5 12 12 5 19 12"></polyline>
  </svg>
</button>

<script>
  const btn = document.getElementById('back-to-top');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 500) {
      btn?.classList.remove('opacity-0', 'pointer-events-none');
      btn?.classList.add('opacity-100');
    } else {
      btn?.classList.add('opacity-0', 'pointer-events-none');
      btn?.classList.remove('opacity-100');
    }
  });

  btn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
